sched_reserve: reserve took 11.44 ms, sched copies = 1
[VMM] bad magic in vmm.bin
[ENGINE] VMM disabled (vmm_model_open failed for GGUF=C:\Projects\AI_Shell-main\Bob-llama-Q4_K_S.gguf VMM=vmm.bin)
OK model_loaded

In vmm_model_open, after mapping the header:

vmm_model_header_t* hdr = (vmm_model_header_t*)hdr_ptr;
if (hdr->magic != VMM_MODEL_MAGIC) {
    fprintf(stderr, "[VMM] bad magic in vmm.bin — rebuilding\n");
    vmm_unmap(vmm, hdr_ptr, 64 * 1024);
    vmm_destroy(vmm);

    // force rebuild
    int rc = vmm_model_build_from_gguf(gguf_path, vmm_path, vmm_budget_bytes);
    if (rc != 0) {
        fprintf(stderr, "[VMM] rebuild_from_gguf FAILED rc=%d\n", rc);
        return NULL;
    }

    // reopen after rebuild
    vmm = vmm_create(vmm_path, 0, VMM_MODE_OPEN_EXISTING);
    if (!vmm) return NULL;

    hdr_ptr = vmm_map(vmm, 0, 64 * 1024);
    if (!hdr_ptr) return NULL;
    hdr = (vmm_model_header_t*)hdr_ptr;
    if (hdr->magic != VMM_MODEL_MAGIC) return NULL;
}

That way:

first run with a broken/old vmm.bin → it auto‑rebuilds

future runs use the new, correct file

